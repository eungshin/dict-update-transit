# Dict Tool — environment variables
#
# Copy this file to .env and fill in your values.
# The daemon reads these from the environment at startup.

# NVIDIA API key for AI contextual meaning disambiguation.
# Get one at: https://build.nvidia.com/
# If absent or empty, AI disambiguation is skipped (all meanings shown).
NVIDIA_API_KEY=

# Optional: override the NVIDIA model used for disambiguation.
# Default: nvidia/llama-3.3-nemotron-super-49b-v1
# NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Google Gemini API key for Gemini TTS voice.
# Get one at: https://aistudio.google.com/apikey
# If absent, Gemini TTS is unavailable (falls back to pyttsx3).
GEMINI_API_KEY=
